# LLM Provider - choose one: openai / anthropic / qwen / minimax
LLM_PROVIDER=openai

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic / Claude (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Qwen / DashScope (required if LLM_PROVIDER=qwen)
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# MiniMax (required if LLM_PROVIDER=minimax)
MINIMAX_API_KEY=your-minimax-key-here
